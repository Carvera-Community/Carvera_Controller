                                ProbeScanFieldLabel:
                                    text: tr._('Retract R')
                                ProbeScanFieldInput:
                                    id: t463_r
                                    hint_text: '1.5'

                            Button:
                                text: tr._('Run inside corner probe')
                                size_hint_y: None
                                height: dp(46)
                                on_release: root.on_in463()

                TabbedPanelItem:
                    text: tr._('Corner out')
                    ScrollView:
                        bar_width: dp(14)
                        scroll_type: ['bars', 'content']
                        padding: dp(16), dp(10), dp(22), dp(14)
                        GridLayout:
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)
                            padding: [dp(14), dp(10), dp(16), dp(12)]

                            Label:
                                text_size: self.width, None
                                markup: True
                                halign: 'left'
                                color: 0.88, 0.88, 0.92, 1
                                size_hint_y: None
                                height: self.texture_size[1]
                                text: tr._("[b]Outside corner[/b]\n[color=78797f][b]M464[/b][/color]")

                            GridLayout:
                                cols: 2
                                spacing: dp(14)
                                padding: dp(8)
                                row_default_height: dp(174)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanIconToggle:
                                    group: 'scan_m464'
                                    image: 'addons/probing/data/icons_1024x768/outside_corner/X+Y+.png'
                                    on_state:
                                        if self.state == 'down': root.on_outside_corner_quick('BottomLeft')
                                ProbeScanIconToggle:
                                    group: 'scan_m464'
                                    image: 'addons/probing/data/icons_1024x768/outside_corner/X-Y+.png'
                                    on_state:
                                        if self.state == 'down': root.on_outside_corner_quick('BottomRight')
                                ProbeScanIconToggle:
