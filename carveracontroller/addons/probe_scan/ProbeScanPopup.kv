                                ProbeScanFieldInput:
                                    id: t464_h
                                    hint_text: '0'
                                ProbeScanFieldLabel:
                                    text: tr._('Clearance C')
                                ProbeScanFieldInput:
                                    id: t464_c
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Probe F')
                                ProbeScanFieldInput:
                                    id: t464_f
                                    text: '300'
                                ProbeScanFieldLabel:
                                    text: tr._('Rapid K')
                                ProbeScanFieldInput:
                                    id: t464_k
                                    text: '800'
                                ProbeScanFieldLabel:
                                    text: tr._('Repeat L')
                                ProbeScanFieldInput:
                                    id: t464_l
                                    hint_text: '1'
                                ProbeScanFieldLabel:
                                    text: tr._('Retract R')
                                ProbeScanFieldInput:
                                    id: t464_r
                                    hint_text: '1.5'

                            Button:
                                text: tr._('Run outside corner probe')
                                size_hint_y: None
                                height: dp(46)
                                on_release: root.on_out464()

                TabbedPanelItem:
                    text: tr._('Angle')
                    ScrollView:
                        bar_width: dp(14)
                        scroll_type: ['bars', 'content']
                        padding: dp(16), dp(10), dp(22), dp(14)
                        GridLayout:
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)
                            padding: [dp(14), dp(10), dp(16), dp(12)]

                            Label:
                                text_size: self.width, None
                                markup: True
                                halign: 'left'
                                color: 0.88, 0.88, 0.92, 1
                                size_hint_y: None
                                height: self.texture_size[1]
                                text: tr._("[b]Axis angle[/b]\n[color=78797f][b]M465[/b][/color]")

                            GridLayout:
                                cols: 2
                                spacing: dp(14)
                                padding: dp(8)
                                row_default_height: dp(174)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanIconToggle:
                                    group: 'scan_m465'
                                    image: 'addons/probing/data/icons_1024x768/angle/probe_angle_x_above.png'
                                    on_state:
                                        if self.state == 'down': root.on_angle_axis_hint('above')
                                ProbeScanIconToggle:
                                    group: 'scan_m465'
                                    image: 'addons/probing/data/icons_1024x768/angle/probe_angle_x_below.png'
                                    on_state:
                                        if self.state == 'down': root.on_angle_axis_hint('below')
                                ProbeScanIconToggle:
                                    group: 'scan_m465'
                                    image: 'addons/probing/data/icons_1024x768/angle/probe_angle_y_left.png'
                                    on_state:
                                        if self.state == 'down': root.on_angle_axis_hint('left')
                                ProbeScanIconToggle:
                                    group: 'scan_m465'
                                    image: 'addons/probing/data/icons_1024x768/angle/probe_angle_y_right.png'
                                    on_state:
                                        if self.state == 'down': root.on_angle_axis_hint('right')

                            GridLayout:
                                cols: 2
                                spacing: dp(4)
                                padding: dp(8)
                                row_default_height: dp(40)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanFieldLabel:
                                    text: tr._('X mm')
                                ProbeScanFieldInput:
                                    id: t465_x
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Y mm')
                                ProbeScanFieldInput:
                                    id: t465_y
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Depth E')
                                ProbeScanFieldInput:
                                    id: t465_e
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Height H')
                                ProbeScanFieldInput:
                                    id: t465_h
                                    hint_text: '0'
                                ProbeScanFieldLabel:
                                    text: tr._('Clearance C')
                                ProbeScanFieldInput:
                                    id: t465_c
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Probe F')
                                ProbeScanFieldInput:
                                    id: t465_f
                                    text: '300'
                                ProbeScanFieldLabel:
                                    text: tr._('Rapid K')
                                ProbeScanFieldInput:
                                    id: t465_k
                                    text: '800'
                                ProbeScanFieldLabel:
                                    text: tr._('Repeat L')
                                ProbeScanFieldInput:
                                    id: t465_l
                                    hint_text: '1'
                                ProbeScanFieldLabel:
                                    text: tr._('Retract R')
                                ProbeScanFieldInput:
                                    id: t465_r
                                    hint_text: '1.5'

                            Button:
                                text: tr._('Measure angle and capture')
                                size_hint_y: None
                                height: dp(46)
                                on_release: root.on_angle465()

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.5
                spacing: dp(6)

                Label:
                    text: tr._('XY preview')
                    size_hint_y: None
                    height: dp(24)
                    font_size: dp(14)

                FloatLayout:
                    size_hint_y: 1

                    ProbeScanPreviewSketch:
                        id: sketch
                        pos_hint: {'x': 0, 'y': 0}
                        size_hint: 1, 1

                    Label:
                        id: lbl_sketch_placeholder
                        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                        size_hint: 0.86, None
                        text: tr._('No features captured yet.\nUse the left-hand tabs to probe or add coordinates from Manual.')
                        color: 0.45, 0.46, 0.52, 0.95
                        font_size: dp(13)
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.width, None

                Label:
                    text: tr._('Features')
                    size_hint_y: None
                    height: dp(24)
                    font_size: dp(14)

                GridLayout:
                    cols: 4
                    size_hint_y: None
                    spacing: dp(4)
                    height: dp(100)
                    Button:
                        text: tr._('Segment')
                        font_size: dp(13)
                        disabled: not root.can_make_segment
                        on_release: root.on_construct_segment()
                    Button:
                        text: tr._('Poly open')
                        font_size: dp(13)
                        disabled: not root.can_make_polyline_open
                        on_release: root.on_construct_polyline_open()
                    Button:
                        text: tr._('Poly closed')
                        font_size: dp(13)
                        disabled: not root.can_make_polyline_closed
                        on_release: root.on_construct_polyline_closed()
                    Button:
                        text: tr._('Circumcircle')
                        font_size: dp(13)
                        disabled: not root.can_make_circumcircle
                        on_release: root.on_construct_derived_circle()
                    Button:
                        text: tr._('Intersect')
                        font_size: dp(13)
                        disabled: not root.can_make_intersection
                        on_release: root.on_construct_intersection()
                    Button:
                        text: tr._('Midpoint')
                        font_size: dp(13)
                        disabled: not root.can_make_midpoint
                        on_release: root.on_construct_midpoint()
                    Button:
                        text: tr._('Tangent')
                        font_size: dp(13)
                        disabled: not root.can_make_tangent
                        on_release: root.on_construct_tangent()
                    Button:
                        text: tr._('Clear sel.')
                        font_size: dp(13)
                        disabled: not root.has_construct_selection
                        on_release: root.on_clear_construct_selection()

                ScrollView:
                    id: feature_rows_scroll
                    size_hint_y: 1
                    bar_width: dp(14)
                    scroll_type: ['bars', 'content']
                    GridLayout:
                        id: feature_rows
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(4)

        BoxLayout:
            id: probing_banner
            size_hint_y: None
            height: dp(40) if root.is_probing else 0
            opacity: 1 if root.is_probing else 0
            padding: dp(10), dp(6), dp(10), dp(6)
            spacing: dp(8)
            canvas.before:
                Color:
                    rgba: 0.12, 0.38, 0.18, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(4), dp(4), dp(4), dp(4)]
            Label:
                text: root.probing_status_text
                color: 0.62, 0.98, 0.68, 1
                font_size: dp(14)
                bold: True
                halign: 'left'
                valign: 'middle'
                text_size: self.width, self.height

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(58)
            spacing: dp(6)
            Button:
                text: tr._('Load...')
                font_size: dp(12)
                size_hint_x: 1
                on_release: root.on_load_session()
            Button:
                text: tr._('Save as...')
                font_size: dp(12)
                size_hint_x: 1
                on_release: root.open_save_format_dropdown(self)
            Button:
                text: tr._('Copy as...')
                font_size: dp(12)
                size_hint_x: 1
                on_release: root.open_copy_format_dropdown(self)
            Button:
                text: tr._('Reset')
                font_size: dp(12)
                size_hint_x: 1
                on_release: root.on_reset_session()
            Button:
                text: tr._('Jog...')
                font_size: dp(12)
                size_hint_x: 1
                on_release: root.open_jog_popup()
            Button:
                text: tr._('Close')
                font_size: dp(12)
                size_hint_x: 1
                on_release: root.dismiss()


<JogProbeScanPopup>:
    size_hint: None, None
    width: min(dp(968), Window.width - dp(48))
    auto_dismiss: True
    overlay_color: 0, 0, 0, 0.4
    background: ''
    background_color: 0, 0, 0, 0
    border: [0, 0, 0, 0]

    canvas.before:
        Color:
            rgba: (38 / 255, 39 / 255, 42 / 255, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10), dp(10), dp(10), dp(10)]

    BoxLayout:
        id: jog_modal_inner
        orientation: 'vertical'
        spacing: dp(0)
        padding: [dp(14), dp(6), dp(14), dp(18)]
        size_hint: 1, None
        height: self.minimum_height

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(29)
            spacing: dp(2)
            Label:
                text: tr._('Jog')
                size_hint_y: None
                height: dp(24)
                font_size: dp(17)
                color: 0.95, 0.96, 0.97, 1
                bold: True
                halign: 'left'
                valign: 'middle'
                text_size: self.width, None

            Widget:
                size_hint_y: None
                height: dp(3)
                canvas:
                    Color:
                        rgba: (50 / 255, 167 / 255, 212 / 255, 0.92)
                    Rectangle:
                        pos: self.pos
                        size: self.size

        BoxLayout:
            spacing: dp(0)
            size_hint_y: None
            height: dp(226)
            GridLayout:
                cols: 5
                rows: 1
                size_hint: 1, 1
                spacing: dp(0)
                padding: dp(0)
                BoxLayout:
                    orientation: 'horizontal'
                    padding: dp(0)
                    canvas.before:
                        Color:
                            rgba: (40 / 255, 40 / 255, 40 / 255, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [self.height / 2, self.height / 2]
                    BoxLayout:
                        disabled: not (app.state == 'Idle' or app.state == 'Run' or app.state == 'Pause') or (app.playing and app.state != 'Pause') or (app.state == 'Run' and app.root.allow_jogging_while_machine_running == '0')
                        padding: dp(0)
                        canvas.before:
                            Color:
                                rgba: (50 / 255, 50 / 255, 50 / 255, 1)
                            Ellipse:
                                pos: self.pos
                                size: self.size
                        GridLayout:
                            cols: 3
                            rows: 3
                            GridBoxLayout:
                            GridBoxLayout:
                                SmallRoundButton:
                                    text: 'Y-'
                                    height: 46
                                    on_press: app.root.controller.jog("Y-{}".format(scan_jog_step_xy.text))
                                    on_release: app.root.controller.stopContinuousJog()
                            GridBoxLayout:
                            GridBoxLayout:
                                SmallRoundButton:
                                    text: 'X-'
                                    height: 46
                                    on_press: app.root.controller.jog("X-{}".format(scan_jog_step_xy.text))
                                    on_release: app.root.controller.stopContinuousJog()
                            GridBoxLayout:
                                Label:
                                Spinner:
                                    id: scan_jog_step_xy
                                    center: 0.5, 0.5
                                    size_hint_y: None
                                    height: dp(39)
                                    text: '10'
                                    values: '10', '1', '0.1', '0.01', '0.005'
                                Label:
                            GridBoxLayout:
                                SmallRoundButton:
                                    text: 'X+'
                                    height: 46
                                    on_press: app.root.controller.jog("X{}".format(scan_jog_step_xy.text))
                                    on_release: app.root.controller.stopContinuousJog()
                            GridBoxLayout:
                            GridBoxLayout:
                                SmallRoundButton:
                                    text: 'Y+'
                                    height: 46
                                    on_press: app.root.controller.jog("Y{}".format(scan_jog_step_xy.text))
                                    on_release: app.root.controller.stopContinuousJog()
                            GridBoxLayout:
                BoxLayout:
                    size_hint_x: 0.1
                    disabled: not (app.state == 'Idle' or app.state == 'Run' or app.state == 'Pause') or (app.playing and app.state != 'Pause') or (app.state == 'Run' and app.root.allow_jogging_while_machine_running == '0')
                    padding: dp(0)
                    orientation: 'horizontal'
                BoxLayout:
                    disabled: not (app.state == 'Idle' or app.state == 'Run' or app.state == 'Pause') or (app.playing and app.state != 'Pause') or (app.state == 'Run' and app.root.allow_jogging_while_machine_running == '0')
                    padding: dp(0)
                    orientation: 'horizontal'
                    canvas.before:
                        Color:
                            rgba: (50 / 255, 50 / 255, 50 / 255, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [5, 5]
                    GridLayout:
                        size_hint_y: 0.9
                        cols: 2
                        rows: 3
                        GridBoxLayout:
                            SmallRoundButton:
                                text: 'A+'
                                height: 46
                                on_press: app.root.controller.jog("A{}".format(scan_jog_step_a.text))
                                on_release: app.root.controller.stopContinuousJog()
                        GridBoxLayout:
                            SmallRoundButton:
                                text: 'Z+'
                                height: 46
                                on_press: app.root.controller.jog("Z{}".format(scan_jog_step_z.text))
                                on_release: app.root.controller.stopContinuousJog()
                        GridBoxLayout:
                            Label:
                            Spinner:
                                id: scan_jog_step_a
                                center: 0.5, 0.5
                                size_hint_y: None
                                height: dp(48)
                                text: '90'
                                values: '90', '10', '1', '0.1'
                            Label:
                        GridBoxLayout:
                            Label:
                            Spinner:
                                id: scan_jog_step_z
                                center: 0.5, 0.5
                                size_hint_y: None
                                height: dp(48)
                                text: '1'
                                values: '10', '1', '0.1', '0.01', '0.005'
                            Label:
                        GridBoxLayout:
                            SmallRoundButton:
                                text: 'A-'
                                height: 46
                                on_press: app.root.controller.jog("A-{}".format(scan_jog_step_a.text))
                                on_release: app.root.controller.stopContinuousJog()
                        GridBoxLayout:
                            SmallRoundButton:
                                text: 'Z-'
                                height: 46
                                on_press: app.root.controller.jog("Z-{}".format(scan_jog_step_z.text))
                                on_release: app.root.controller.stopContinuousJog()
                BoxLayout:
                    size_hint_x: 0.1
                    disabled: not (app.state == 'Idle' or app.state == 'Run' or app.state == 'Pause') or (app.playing and app.state != 'Pause') or (app.state == 'Run' and app.root.allow_jogging_while_machine_running == '0')
                    padding: dp(0)
                    orientation: 'horizontal'
                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(4)
                    size_hint: 1, 1
                    BoxLayout:
                        padding: dp(4)
                        canvas.before:
                            Color:
                                rgba: (50 / 255, 50 / 255, 50 / 255, 1)
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12),]
                        GridLayout:
                            cols: 2
                            rows: 2
                            spacing: dp(4)
                            GridBoxLayout:
                                Button:
                                    text: app.jog_speed_text
                                    id: jog_speed_btn_scan
                                    center: 0.5, 0.5
                                    height: dp(52)
                                    text_size: self.width - dp(12), None
                                    valign: 'middle'
                                    halign: 'center'
                                    on_release: app.root.jog_speed_drop_down.open(self)
                            GridBoxLayout:
                                Button:
                                    id: jog_mode_btn_scan
                                    disabled: not (app.is_community_firmware and app.fw_version_digitized >= digitize_v("2.0.0"))
                                    text: app.jog_mode_text
                                    height: dp(52)
                                    text_size: self.width - dp(12), None
                                    valign: 'middle'
                                    halign: 'center'
                                    on_release: app.root.toggle_jog_mode()
                            GridBoxLayout:
                                ToggleButton:
                                    id: kb_jog_btn_scan
                                    text: tr._('Keyboard Jogging')
                                    height: dp(52)
                                    text_size: self.width - dp(12), None
                                    valign: 'middle'
                                    halign: 'center'
                                    state: app.jog_keyboard_enable
                                    on_release: app.root.toggle_keyboard_jog_control()
                            GridBoxLayout:
                                ToggleButton:
                                    id: pendant_jog_btn_scan
                                    text: app.jog_pendant_text
                                    state: app.jog_pendant_enable
                                    disabled: app.jog_pendant_text == tr._('No Pendant')
                                    height: dp(52)
                                    text_size: self.width - dp(12), None
                                    valign: 'middle'
                                    halign: 'center'
                                    on_release: app.root.toggle_pendant_jog_control()
        Widget:
            size_hint_y: None
            height: dp(12)
        Button:
            text: tr._('Close')
            size_hint_y: None
            height: dp(58)
            on_release: root.dismiss()
