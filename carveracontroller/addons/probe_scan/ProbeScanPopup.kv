                            GridLayout:
                                cols: 2
                                spacing: dp(4)
                                padding: dp(8)
                                row_default_height: dp(40)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanFieldLabel:
                                    text: tr._('X mm')
                                ProbeScanFieldInput:
                                    id: t462_x
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Y mm')
                                ProbeScanFieldInput:
                                    id: t462_y
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Depth E')
                                ProbeScanFieldInput:
                                    id: t462_e
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Clearance J')
                                ProbeScanFieldInput:
                                    id: t462_j
                                    hint_text: '4'
                                ProbeScanFieldLabel:
                                    text: tr._('Height H')
                                ProbeScanFieldInput:
                                    id: t462_h
                                    hint_text: '0'
                                ProbeScanFieldLabel:
                                    text: tr._('Clearance C')
                                ProbeScanFieldInput:
                                    id: t462_c
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Probe F')
                                ProbeScanFieldInput:
