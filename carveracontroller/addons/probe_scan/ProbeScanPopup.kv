#:import tr carveracontroller.__main__.tr
#:import digitize_v carveracontroller.Utils.digitize_v
#:import Window kivy.core.window.Window


<ProbeScanIconToggle>:
    background_color: 0, 0, 0, 0
    group: ''
    canvas.before:
        Color:
            rgba: (88/255, 88/255, 88/255, 1) if self.state == 'normal' else (50/255, 164/255, 206/255, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(3),]
    Image:
        source: root.image
        size: self.parent.size
        fit_mode: 'scale-down'
        pos: self.parent.pos


<ProbeScanFieldLabel@Label>:
    font_size: dp(15)
    color: 0.88, 0.88, 0.92, 1
    halign: 'center'
    valign: 'middle'
    text_size: self.size

<ProbeScanFieldInput@TextInput>:
    multiline: False
    font_size: dp(15)
    size_hint_y: None
    height: dp(40)
    halign: 'right'
    padding: [dp(10), dp(8), dp(10), dp(8)]
    input_filter: 'float'


<ProbeScanFileSheet@BoxLayout>:
    orientation: 'vertical'
    padding: dp(8)
    spacing: dp(8)
    Label:
        text: tr._('Choose folder and file name')
        size_hint_y: None
        height: dp(22)
        font_size: dp(11)
        text_size: self.width, None
        halign: 'left'
        color: 0.78, 0.79, 0.82, 1
    FileChooserListView:
        id: fc
        size_hint_y: 0.6
    Label:
        text: tr._('File name')
        size_hint_y: None
        height: dp(18)
        font_size: dp(10)
        halign: 'left'
        text_size: self.width, None
    TextInput:
        id: ti_filename
        multiline: False
        size_hint_y: None
        height: dp(36)
    BoxLayout:
        size_hint_y: None
        height: dp(44)
        spacing: dp(8)
        Button:
            id: btn_cancel
            text: tr._('Cancel')
        Button:
            id: btn_save
            text: tr._('Save')


<ProbeScanPopup>:
    title: tr._('Probe scan')
    size_hint: 0.9, 0.88
    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    auto_dismiss: False
    overlay_color: 0, 0, 0, 0.35

    BoxLayout:
        orientation: 'vertical'
        padding: dp(8)
        spacing: dp(6)

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 1
            spacing: dp(8)

            TabbedPanel:
                size_hint_x: 0.55
                do_default_tab: False
                tab_width: dp(118)
                bar_width: dp(8)
                bar_color: 0.52, 0.68, 0.85, 1
                padding: dp(6), dp(8), dp(6), dp(10)
                disabled: root.is_probing

                TabbedPanelItem:
                    text: tr._('Manual')
                    ScrollView:
                        bar_width: dp(14)
                        scroll_type: ['bars', 'content']
                        padding: dp(16), dp(10), dp(22), dp(14)
                        GridLayout:
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(10)
                            padding: [dp(14), dp(10), dp(16), dp(12)]

                            Label:
                                text_size: self.width, None
                                size_hint_y: None
                                height: self.texture_size[1]
                                markup: True
                                halign: 'left'
                                color: 0.88, 0.88, 0.92, 1
                                text: tr._("[b]Manual (no motion)[/b]\n[color=78797f]Live position is shown below. Load it into the fields or type your own, then add a point or circle.[/color]")
                            BoxLayout:
                                orientation: 'horizontal'
                                size_hint_y: None
                                height: dp(72)
                                spacing: dp(8)
                                Widget:
                                    size_hint_x: 1
                                Label:
                                    id: lbl_wcs_live
                                    size_hint_x: None
                                    size_hint_y: 1
                                    width: dp(292)
                                    font_size: dp(13)
                                    halign: 'right'
                                    valign: 'middle'
                                    text_size: self.width, self.height
                                    markup: True
                                    color: 0.65, 0.92, 0.98, 1
                                    text: ''
                                AnchorLayout:
                                    size_hint_x: None
                                    width: dp(136)
                                    anchor_y: 'center'
                                    Button:
                                        size_hint: None, None
                                        width: dp(136)
                                        height: dp(48)
                                        text: tr._('Load coordinates')
                                        font_size: dp(12)
                                        on_release: root.on_manual_sync_from_machine()

                            GridLayout:
                                cols: 2
                                spacing: dp(4)
                                padding: dp(0), dp(4), dp(0), dp(2)
                                row_default_height: dp(40)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanFieldLabel:
                                    text: tr._('X mm')
                                ProbeScanFieldInput:
                                    id: t_manual_wx
                                ProbeScanFieldLabel:
                                    text: tr._('Y mm')
                                ProbeScanFieldInput:
                                    id: t_manual_wy
                                ProbeScanFieldLabel:
                                    text: tr._('Z mm')
                                ProbeScanFieldInput:
                                    id: t_manual_wz
                                ProbeScanFieldLabel:
                                    text: tr._('Radius mm')
                                ProbeScanFieldInput:
                                    id: t_manual_radius

                            Button:
                                text: tr._('Add point')
                                size_hint_y: None
                                height: dp(48)
                                on_release: root.on_add_current_position()

                            Button:
                                text: tr._('Add circle')
                                size_hint_y: None
                                height: dp(48)
                                on_release: root.on_add_manual_circle()

                TabbedPanelItem:
                    text: tr._('Touch')
                    ScrollView:
                        bar_width: dp(14)
                        scroll_type: ['bars', 'content']
                        padding: dp(16), dp(10), dp(22), dp(14)
                        GridLayout:
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)
                            padding: [dp(14), dp(10), dp(16), dp(12)]

                            Label:
                                text_size: self.width, None
                                size_hint_y: None
                                height: self.texture_size[1]
                                markup: True
                                halign: 'left'
                                color: 0.88, 0.88, 0.92, 1
                                text: tr._("[b]Single-axis probe[/b]\n[color=78797f][b]M466[/b][/color]")

                            GridLayout:
                                cols: 2
                                spacing: dp(12)
                                padding: dp(8)
                                row_default_height: dp(146)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanIconToggle:
                                    group: 'scan_m466'
                                    image: 'addons/probing/data/icons_1024x768/single_axis/X+.png'
                                    on_state:
                                        if self.state == 'down': root.on_probe_side_hint('Left')
                                ProbeScanIconToggle:
                                    group: 'scan_m466'
                                    image: 'addons/probing/data/icons_1024x768/single_axis/X-.png'
                                    on_state:
                                        if self.state == 'down': root.on_probe_side_hint('Right')
                                ProbeScanIconToggle:
                                    group: 'scan_m466'
                                    image: 'addons/probing/data/icons_1024x768/single_axis/Y+.png'
                                    on_state:
                                        if self.state == 'down': root.on_probe_side_hint('Bottom')
                                ProbeScanIconToggle:
                                    group: 'scan_m466'
                                    image: 'addons/probing/data/icons_1024x768/single_axis/Y-.png'
                                    on_state:
                                        if self.state == 'down': root.on_probe_side_hint('Top')

                            GridLayout:
                                cols: 2
                                spacing: dp(4)
                                padding: dp(8)
                                row_default_height: dp(40)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanFieldLabel:
                                    text: tr._('X mm')
                                ProbeScanFieldInput:
                                    id: t466_x
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Y mm')
                                ProbeScanFieldInput:
                                    id: t466_y
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Probe F')
                                ProbeScanFieldInput:
                                    id: t466_f
                                    text: '300'
                                ProbeScanFieldLabel:
                                    text: tr._('Rapid K')
                                ProbeScanFieldInput:
                                    id: t466_k
                                    text: '800'
                                ProbeScanFieldLabel:
                                    text: tr._('Depth E')
                                ProbeScanFieldInput:
                                    id: t466_e
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Height H')
                                ProbeScanFieldInput:
                                    id: t466_h
                                    hint_text: '0'
                                ProbeScanFieldLabel:
                                    text: tr._('Clearance C')
                                ProbeScanFieldInput:
                                    id: t466_c
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Repeat L')
                                ProbeScanFieldInput:
                                    id: t466_l
                                    hint_text: '1'
                                ProbeScanFieldLabel:
                                    text: tr._('Retract R')
                                ProbeScanFieldInput:
                                    id: t466_r
                                    hint_text: '1.5'

                            Button:
                                text: tr._('Run probe and capture')
                                size_hint_y: None
                                height: dp(46)
                                on_release: root.on_probe_axis466()

                TabbedPanelItem:
                    text: tr._('Bore')
                    ScrollView:
                        bar_width: dp(14)
                        scroll_type: ['bars', 'content']
                        padding: dp(16), dp(10), dp(22), dp(14)
                        GridLayout:
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)
                            padding: [dp(14), dp(10), dp(16), dp(12)]

                            Label:
                                text_size: self.width, None
                                markup: True
                                halign: 'left'
                                color: 0.88, 0.88, 0.92, 1
                                size_hint_y: None
                                height: self.texture_size[1]
                                text: tr._("[b]Circular pocket / bore center[/b]\n[color=78797f][b]M461[/b][/color]")

                            GridLayout:
                                cols: 2
                                spacing: dp(14)
                                padding: dp(8)
                                row_default_height: dp(174)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanIconToggle:
                                    group: 'scan_m461'
                                    image: 'addons/probing/data/icons_1024x768/inside_center/inside_center_rectangular_pocket_x.png'
                                    on_state:
                                        if self.state == 'down': root.on_bore_preset('CenterX')
                                ProbeScanIconToggle:
                                    group: 'scan_m461'
                                    image: 'addons/probing/data/icons_1024x768/inside_center/inside_center_rectangular_pocket_y.png'
                                    on_state:
                                        if self.state == 'down': root.on_bore_preset('CenterY')
                                ProbeScanIconToggle:
                                    group: 'scan_m461'
                                    image: 'addons/probing/data/icons_1024x768/inside_center/inside_center_circular_bore.png'
                                    on_state:
                                        if self.state == 'down': root.on_bore_preset('CenterBore')
                                ProbeScanIconToggle:
                                    group: 'scan_m461'
                                    image: 'addons/probing/data/icons_1024x768/inside_center/inside_center_rectangular_pocket.png'
                                    on_state:
                                        if self.state == 'down': root.on_bore_preset('CenterPocket')

                            GridLayout:
                                cols: 2
                                spacing: dp(4)
                                padding: dp(8)
                                row_default_height: dp(40)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanFieldLabel:
                                    text: tr._('X mm')
                                ProbeScanFieldInput:
                                    id: t461_x
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Y mm')
                                ProbeScanFieldInput:
                                    id: t461_y
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Probe F')
                                ProbeScanFieldInput:
                                    id: t461_f
                                    text: '300'
                                ProbeScanFieldLabel:
                                    text: tr._('Rapid K')
                                ProbeScanFieldInput:
                                    id: t461_k
                                    text: '800'
                                ProbeScanFieldLabel:
                                    text: tr._('Depth E')
                                ProbeScanFieldInput:
                                    id: t461_e
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Height H')
                                ProbeScanFieldInput:
                                    id: t461_h
                                    hint_text: '0'
                                ProbeScanFieldLabel:
                                    text: tr._('Clearance C')
                                ProbeScanFieldInput:
                                    id: t461_c
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Repeat L')
                                ProbeScanFieldInput:
                                    id: t461_l
                                    hint_text: '1'
                                ProbeScanFieldLabel:
                                    text: tr._('Retract R')
                                ProbeScanFieldInput:
                                    id: t461_r
                                    hint_text: '1.5'

                            Button:
                                text: tr._('Run bore probe and capture')
                                size_hint_y: None
                                height: dp(46)
                                on_release: root.on_bore461()

                TabbedPanelItem:
                    text: tr._('Boss')
                    ScrollView:
                        bar_width: dp(14)
                        scroll_type: ['bars', 'content']
                        padding: dp(16), dp(10), dp(22), dp(14)
                        GridLayout:
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)
                            padding: [dp(14), dp(10), dp(16), dp(12)]

                            Label:
                                text_size: self.width, None
                                markup: True
                                halign: 'left'
                                color: 0.88, 0.88, 0.92, 1
                                size_hint_y: None
                                height: self.texture_size[1]
                                text: tr._("[b]Outside boss / block center[/b]\n[color=78797f][b]M462[/b][/color]")

                            GridLayout:
                                cols: 2
                                spacing: dp(14)
                                padding: dp(8)
                                row_default_height: dp(174)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanIconToggle:
                                    group: 'scan_m462'
                                    image: 'addons/probing/data/icons_1024x768/outside_center/outside_center_rect_boss_x.png'
                                    on_state:
                                        if self.state == 'down': root.on_boss_preset('CenterX')
                                ProbeScanIconToggle:
                                    group: 'scan_m462'
                                    image: 'addons/probing/data/icons_1024x768/outside_center/outside_center_rect_boss_y.png'
                                    on_state:
                                        if self.state == 'down': root.on_boss_preset('CenterY')
                                ProbeScanIconToggle:
                                    group: 'scan_m462'
                                    image: 'addons/probing/data/icons_1024x768/outside_center/outside_center_circular_boss.png'
                                    on_state:
                                        if self.state == 'down': root.on_boss_preset('CenterBoss')
                                ProbeScanIconToggle:
                                    group: 'scan_m462'
                                    image: 'addons/probing/data/icons_1024x768/outside_center/outside_center_rect_boss.png'
                                    on_state:
