                                    text: '300'
                                ProbeScanFieldLabel:
                                    text: tr._('Rapid K')
                                ProbeScanFieldInput:
                                    id: t462_k
                                    text: '800'
                                ProbeScanFieldLabel:
                                    text: tr._('Repeat L')
                                ProbeScanFieldInput:
                                    id: t462_l
                                    hint_text: '1'
                                ProbeScanFieldLabel:
                                    text: tr._('Retract R')
                                ProbeScanFieldInput:
                                    id: t462_r
                                    hint_text: '1.5'

                            Button:
                                text: tr._('Run boss probe and capture')
                                size_hint_y: None
                                height: dp(46)
                                on_release: root.on_boss462()

                TabbedPanelItem:
                    text: tr._('Corner in')
                    ScrollView:
                        bar_width: dp(14)
                        scroll_type: ['bars', 'content']
                        padding: dp(16), dp(10), dp(22), dp(14)
                        GridLayout:
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)
                            padding: [dp(14), dp(10), dp(16), dp(12)]

                            Label:
                                text_size: self.width, None
                                markup: True
                                halign: 'left'
                                color: 0.88, 0.88, 0.92, 1
                                size_hint_y: None
                                height: self.texture_size[1]
                                text: tr._("[b]Inside corner[/b]\n[color=78797f][b]M463[/b][/color]")

                            GridLayout:
                                cols: 2
                                spacing: dp(14)
                                padding: dp(8)
                                row_default_height: dp(174)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanIconToggle:
                                    group: 'scan_m463'
                                    image: 'addons/probing/data/icons_1024x768/inside_corner/inX+Y+.png'
                                    on_state:
                                        if self.state == 'down': root.on_inside_corner_quick('BottomLeft')
                                ProbeScanIconToggle:
                                    group: 'scan_m463'
                                    image: 'addons/probing/data/icons_1024x768/inside_corner/inX-Y+.png'
                                    on_state:
                                        if self.state == 'down': root.on_inside_corner_quick('BottomRight')
                                ProbeScanIconToggle:
                                    group: 'scan_m463'
                                    image: 'addons/probing/data/icons_1024x768/inside_corner/inX+Y-.png'
                                    on_state:
                                        if self.state == 'down': root.on_inside_corner_quick('TopLeft')
                                ProbeScanIconToggle:
                                    group: 'scan_m463'
                                    image: 'addons/probing/data/icons_1024x768/inside_corner/inX-Y-.png'
                                    on_state:
                                        if self.state == 'down': root.on_inside_corner_quick('TopRight')

                            GridLayout:
                                cols: 2
                                spacing: dp(4)
                                padding: dp(8)
                                row_default_height: dp(40)
                                row_force_default: True
                                size_hint_y: None
                                height: self.minimum_height
                                ProbeScanFieldLabel:
                                    text: tr._('X mm')
                                ProbeScanFieldInput:
                                    id: t463_x
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Y mm')
                                ProbeScanFieldInput:
                                    id: t463_y
                                    text: '10'
                                ProbeScanFieldLabel:
                                    text: tr._('Depth E')
                                ProbeScanFieldInput:
                                    id: t463_e
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Height H')
                                ProbeScanFieldInput:
                                    id: t463_h
