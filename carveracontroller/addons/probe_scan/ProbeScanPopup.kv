                                ProbeScanFieldLabel:
                                    text: tr._('Clearance C')
                                ProbeScanFieldInput:
                                    id: t463_c
                                    hint_text: '2'
                                ProbeScanFieldLabel:
                                    text: tr._('Probe F')
                                ProbeScanFieldInput:
                                    id: t463_f
                                    text: '300'
                                ProbeScanFieldLabel:
                                    text: tr._('Rapid K')
                                ProbeScanFieldInput:
                                    id: t463_k
                                    text: '800'
                                ProbeScanFieldLabel:
